# Production MP3 chord API. Server-only; never expose this key to the browser.
CHORD_ENGINE_PROVIDER=klangio
KLANGIO_API_KEY=
KLANGIO_API_URL=https://api.klang.io
KLANGIO_VOCABULARY=full
KLANGIO_EXTENDED=true
KLANGIO_TIMEOUT_MS=270000
KLANGIO_POLL_INTERVAL_MS=2500

# Optional self-hosted ChordMini fallback.
CHORDMINI_API_URL=http://localhost:5001
CHORD_ENGINE_DETECTOR=chord-cnn-lstm
CHORD_ENGINE_DICT=full
